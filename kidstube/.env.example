GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# YouTube Data API v3 — cuota del proyecto para modo invitado (sin login).
# Obligatoria si quieres navegar sin cuenta; con sesión Google se usa OAuth del usuario.
YOUTUBE_API_KEY=
# Auth.js / NextAuth — obligatorio (usa uno; recomendado AUTH_SECRET):
AUTH_SECRET=
# NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Opcional — SQLite servidor (blacklist, PIN parental por user_id; futuro historial en prompt 12).
# Prioridad: KIDSTUBE_SERVER_DB_PATH, si no BLACKLIST_DB_PATH, si no default ./data/kidstube.sqlite
# KIDSTUBE_SERVER_DB_PATH=
# BLACKLIST_DB_PATH=
# Si venías del default antiguo: mv data/kidstube-blacklist.sqlite data/kidstube.sqlite (o apunta BLACKLIST_DB_PATH al fichero viejo).
