{
  "name": "peketube-repo",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "prepare": "pnpm install -C peketube",
    "dev": "pnpm -C peketube dev",
    "dev:lan": "pnpm -C peketube dev:lan",
    "build": "pnpm -C peketube build",
    "start": "pnpm -C peketube start",
    "lint": "pnpm -C peketube lint",
    "typecheck": "pnpm -C peketube typecheck",
    "install:app": "pnpm install -C peketube"
  }
}
