GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# YouTube Data API v3 — cuota del proyecto para modo invitado (sin login).
# Obligatoria si quieres navegar sin cuenta; con sesión Google se usa OAuth del usuario.
YOUTUBE_API_KEY=
# Auth.js / NextAuth — obligatorio (usa uno; recomendado AUTH_SECRET):
AUTH_SECRET=
# NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Producción detrás de proxy (Caddy/Nginx): necesario para que NextAuth confíe en X-Forwarded-*.
# AUTH_TRUST_HOST=true
# Opcional — SQLite servidor (blacklist, PIN parental, historial por user_id).
# Prioridad: PEKETUBE_SERVER_DB_PATH, si no KIDSTUBE_SERVER_DB_PATH (deprecado),
# si no BLACKLIST_DB_PATH (deprecado), si no ./data/peketube.sqlite.
# PEKETUBE_SERVER_DB_PATH=
# KIDSTUBE_SERVER_DB_PATH=
# BLACKLIST_DB_PATH=
# Si vienes de KidsTube: apunta PEKETUBE_SERVER_DB_PATH al fichero antiguo
# (data/kidstube.sqlite) o renómbralo a data/peketube.sqlite.
# Landing pública (peketubeinfo.amian.es) — opcional en dev:
# PEKETUBE_INFO_HOST=peketubeinfo.amian.es
# NEXT_PUBLIC_PEKETUBE_APP_URL=https://peketube.amian.es
# Formulario de contacto (SMTP — el destino no se muestra al usuario):
# CONTACT_TO_EMAIL=amiansito84@gmail.com
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=contacto@amian.es
# SMTP_PASS=
# CONTACT_FROM_EMAIL=peketube@amian.es
# Logs rotativos (fichero diario, retención 7 días por defecto):
# PEKETUBE_LOG_DIR=./data/logs
# PEKETUBE_LOG_RETENTION_DAYS=7
# PEKETUBE_LOG_DISABLED=false
# Visor /logs y /stats (HTTP Basic Auth — equivalente a htaccess):
# LOG_VIEWER_USER=admin
# LOG_VIEWER_PASS=cambiar-esto
# (Las estadísticas de uso se guardan en el mismo SQLite: logins OAuth, vídeos, sesiones)
